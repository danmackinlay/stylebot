# stylebot secrets — copy to `.env` and fill in. NEVER commit `.env`.
# `.env` is gitignored. Load it via `stylebot.config` (python-dotenv).
#
# Not every phase needs every key. Fill them in as you reach each phase;
# see _plans/OVERVIEW.md for which phase uses what.

# ---- Corpus location (optional; not a secret) ----
# Path to the private training corpus. Defaults to ./_training_pairs.
# STYLEBOT_DATA_DIR=/path/to/your/corpus

# ---- Phase 2: synthetic-pair generation (LLMs that produce the "slop") ----
# Multi-source by design — see the post. Fill in whichever you use.
OPENAI_API_KEY=
# Local/utility base model (e.g. via an OpenAI-compatible endpoint).
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_API_KEY=

# ---- Phase 3: LoRA training & serving ----
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
# TINKER_API_KEY=

# ---- Eval harness: statistical AI-text detector ----
PANGRAM_API_KEY=
