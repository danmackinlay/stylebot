{
  "name": "voice-marker",
  "displayName": "Voice Marker",
  "description": "Mark paragraphs with P(slop) from a stylebot voice-classifier sidecar (ai-style serve)",
  "version": "0.0.1",
  "publisher": "danmackinlay",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/danmackinlay/stylebot"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:quarto"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "voiceMarker.rescore",
        "title": "Voice Marker: Rescore Document"
      },
      {
        "command": "voiceMarker.toggle",
        "title": "Voice Marker: Toggle Marks"
      },
      {
        "command": "voiceMarker.restartSidecar",
        "title": "Voice Marker: Restart Sidecar"
      }
    ],
    "configuration": {
      "title": "Voice Marker",
      "properties": {
        "voiceMarker.command": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Sidecar command as argv, e.g. `[\"uv\", \"run\", \"--project\", \"/path/to/blog\", \"ai-style\", \"serve\", \"--detector-model\", \"_models/voice-clf\"]`. Empty = extension stays dormant (set this per workspace, not globally)."
        },
        "voiceMarker.cwd": {
          "type": "string",
          "default": "",
          "description": "Working directory for the sidecar spawn (so relative --detector-model paths resolve). Empty = first workspace folder."
        },
        "voiceMarker.thresholds": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "default": [0.5, 0.55, 0.6, 0.65],
          "description": "Ascending P(slop) bucket edges; a paragraph below the first edge gets no mark. Calibrate to your detector's score distribution (quantiles), not equal-width bins."
        },
        "voiceMarker.minChars": {
          "type": "number",
          "default": 80,
          "description": "Skip paragraphs shorter than this (short texts score noisily)."
        },
        "voiceMarker.debounceMs": {
          "type": "number",
          "default": 500,
          "description": "Idle time after an edit before rescoring."
        },
        "voiceMarker.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show P(slop) marks."
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run compile -- --watch",
    "pretest": "tsc -p ./",
    "test": "node --test \"out/test/*.test.js\"",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --skip-license"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0"
  }
}
